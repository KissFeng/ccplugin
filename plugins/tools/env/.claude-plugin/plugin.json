{
  "name": "env",
  "description": "环境处理插件 - 从 .env 文件加载环境变量并注入会话",
  "author": {
    "name": "ccplugin",
    "email": "info@ccplugin.dev",
    "url": "https://github.com/KissFeng/ccplugin"
  },
  "homepage": "https://github.com/KissFeng/ccplugin",
  "repository": "https://github.com/KissFeng/ccplugin",
  "license": "AGPL-3.0-or-later",
  "keywords": [
    "env",
    "environment",
    "plugin",
    "ccplugin"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_NAME=env uvx --from git+https://github.com/KissFeng/ccplugin.git@master update",
            "async": true,
            "timeout": 300
          }
        ]
      }
    ]
  }
}
