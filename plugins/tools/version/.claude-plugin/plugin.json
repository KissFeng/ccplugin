{
  "name": "version",
  "description": "版本号管理插件 - 提供 SemVer 版本管理，支持自动版本更新和手动版本设置",
  "author": {
    "name": "KissFeng",
    "email": "kissfeng66@gmail.com",
    "url": "https://github.com/KissFeng"
  },
  "homepage": "https://github.com/KissFeng/ccplugin/tree/master/plugins/tools/version",
  "repository": "https://github.com/KissFeng/ccplugin/tree/master/plugins/tools/version",
  "license": "AGPL-3.0-or-later",
  "keywords": [
    "version",
    "semver",
    "versioning",
    "release",
    "management"
  ],
  "commands": [
    "./commands/version.md"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_NAME=version uv run --directory ${CLAUDE_PLUGIN_ROOT} ./scripts/main.py hooks",
            "async": true,
            "timeout": 300
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_NAME=version uv run --directory ${CLAUDE_PLUGIN_ROOT} ./scripts/main.py hooks",
            "async": true,
            "timeout": 300
          }
        ]
      }
    ]
  }
}
