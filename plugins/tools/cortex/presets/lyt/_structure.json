    {"src": "seed/_index.md", "dst_key": "concepts", "name": "_index.md"},
    {"src": "seed/_index.md", "dst_key": "entities", "name": "_index.md"},
    {"src": "seed/_index.md", "dst_key": "domains", "name": "_index.md"},
    {"src": "seed/_index.md", "dst_key": "sources", "name": "_index.md"},
    {"src": "seed/_index.md", "dst_key": "questions", "name": "_index.md"},
    {"src": "seed/_index.md", "dst_key": "dashboards", "name": "_index.md"},
    {"src": "seed/_index.md", "dst_key": "fleeting", "name": "_index.md"},
    {"src": "seed/_index.md", "dst_key": "archive", "name": "_index.md"}
  ]
