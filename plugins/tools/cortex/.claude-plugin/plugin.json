{
  "name": "cortex",
  "description": "Cortex — Obsidian 知识库协作插件: hooks 注入、CLI/MCP 操作、模板/lint/refactor、SessionStart 协作约定 + Stop 自动落档",
  "author": {
    "name": "KissFeng",
    "email": "kissfeng66@gmail.com",
    "url": "https://github.com/KissFeng"
  },
  "homepage": "https://github.com/KissFeng/ccplugin/tree/master/plugins/tools/cortex",
  "repository": "https://github.com/KissFeng/ccplugin/tree/master/plugins/tools/cortex",
  "license": "AGPL-3.0-or-later",
  "agents": [
    "./agents/cortex-archivist.md",
    "./agents/cortex-cartographer.md",
    "./agents/cortex-curator.md",
    "./agents/cortex-historian.md",
    "./agents/cortex-linker.md",
    "./agents/cortex-researcher.md",
    "./agents/cortex-summarizer.md",
    "./agents/cortex-translator.md"
  ],
  "commands": [
    "./commands/lint.md",
    "./commands/dashboard.md",
    "./commands/doctor.md",
    "./commands/init.md",
    "./commands/promote.md",
    "./commands/forget.md",
    "./commands/digest.md",
    "./commands/compact.md",
    "./commands/warden.md",
    "./commands/archive.md",
    "./commands/update.md",
    "./commands/install_cron.md",
    "./commands/config.md",
    "./commands/search.md",
    "./commands/save.md",
    "./commands/ingest.md",
    "./commands/memory.md",
    "./commands/recall.md",
    "./commands/refactor.md"
  ],
  "skills": [
    "./skills/cortex-canvas",
    "./skills/cortex-config",
    "./skills/cortex-dashboard",
    "./skills/cortex-doctor",
    "./skills/cortex-image",
    "./skills/cortex-ingest",
    "./skills/cortex-ingest-bulk",
    "./skills/cortex-install",
    "./skills/cortex-lint",
    "./skills/cortex-locale",
    "./skills/cortex-new",
    "./skills/cortex-refactor",
    "./skills/cortex-save",
    "./skills/cortex-search",
    "./skills/cortex-session"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/marketplaces/ccplugin-market/plugins/tools/cortex/scripts/hooks/session_start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/marketplaces/ccplugin-market/plugins/tools/cortex/scripts/hooks/stop.sh",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/marketplaces/ccplugin-market/plugins/tools/cortex/scripts/hooks/stop.sh",
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/marketplaces/ccplugin-market/plugins/tools/cortex/scripts/hooks/post_compact.sh",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/marketplaces/ccplugin-market/plugins/tools/cortex/scripts/hooks/user_prompt_submit.sh",
            "async": false
          }
        ]
      }
    ]
  },
  "keywords": [
    "obsidian",
    "pkm",
    "wiki",
    "zettelkasten",
    "lyt",
    "para",
    "second-brain",
    "auto-archive",
    "session-recap"
  ]
}